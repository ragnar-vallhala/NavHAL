mainmenu "NavHAL Configuration System"

menu "Target Platform Configuration"

config BOARD
    string "Target Board"
    default "nucleo_f401re"
    help
      Name of the target development board (e.g., nucleo_f401re).

config VENDOR
    string "Target Vendor"
    default "stm32"
    help
      Silicon vendor (e.g., stm32).

config CMAKE_SYSTEM_PROCESSOR
    string "Target Processor"
    default "cortex-m4"
    help
      Processor core model (e.g., cortex-m4).

config USE_FPU
    bool "Enable Hardware FPU"
    default y
    help
      Enable hardware Floating Point Unit compiler and linker flags.

endmenu

menu "HAL Drivers Configuration"

config DRV_GPIO
    bool "Enable GPIO Driver"
    default y

config DRV_CLOCK
    bool "Enable Clock Driver"
    default y

config DRV_UART
    bool "Enable UART Driver"
    default y

config DRV_TIMER
    bool "Enable Timer Driver"
    default y

config DRV_INTERRUPT
    bool "Enable Interrupt Driver"
    default y

config DRV_PWM
    bool "Enable PWM Driver"
    default y

config DRV_I2C
    bool "Enable I2C Driver"
    default y

config DRV_SPI
    bool "Enable SPI Driver"
    default y

config DRV_FLASH
    bool "Enable Flash Driver"
    default y

config DRV_DMA
    bool "Enable DMA Driver"
    default y

config DRV_FPU
    bool "Enable FPU Driver"
    default y

config DRV_CRC
    bool "Enable CRC Driver"
    default y

config DRV_SDIO
    bool "Enable SDIO Driver"
    default y

config DRV_DWT
    bool "Enable DWT Driver"
    default y

endmenu

menu "Build Options"

config STANDALONE
    bool "Build Standalone Samples (without full HAL)"
    default n

config SAMPLE
    string "Sample Name"
    default ""
    help
      The name of the sample to build (e.g., hal_blink).

config TEST
    bool "Build Unit Tests"
    default n

config FLASHER
    string "Binary Flasher Tool"
    default "st-flash"

config FLASH_ADDRESS
    string "Flash Target Address"
    default "0x8000000"

endmenu
