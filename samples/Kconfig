# NavHAL samples — M7 §7.3.
#
# Sourced from the root Kconfig's "Build Options" menu. Adding a new sample
# is one new `config SAMPLE_<NN>_<NAME>` entry here, plus the matching
# `default "<slug>" if SAMPLE_<NN>_<NAME>` line at the bottom.
#
# `depends on ARCH_CORTEX_M4` gates samples that need a cortex-specific
# peripheral or driver; `select DRV_<X>` pulls in the cap a sample needs
# so users running with a stripped .config still get the right driver
# linked in (the build_all_samples CI matrix catches missing selects).

choice
    prompt "Sample Application"
    default SAMPLE_NONE
    help
      Select the sample application to compile.

config SAMPLE_NONE
    bool "None"

config SAMPLE_01_HAL_BLINK
    bool "01_hal_blink"

config SAMPLE_01_NO_HAL_BLINK
    bool "01_no_hal_blink"
    depends on ARCH_CORTEX_M4

config SAMPLE_02_HAL_PUPD
    bool "02_hal_pupd"

config SAMPLE_03_HAL_UART_TX
    bool "03_hal_uart_tx"

config SAMPLE_03_NO_HAL_UART_TX
    bool "03_no_hal_uart_tx"
    depends on ARCH_CORTEX_M4

config SAMPLE_04_HAL_TIMER
    bool "04_hal_timer"

config SAMPLE_05_HAL_SYSTICK
    bool "05_hal_systick"
    depends on ARCH_CORTEX_M4

config SAMPLE_06_HAL_BLINK_DELAY
    bool "06_hal_blink_delay"

config SAMPLE_07_HAL_PWM
    bool "07_hal_pwm"
    select DRV_PWM

config SAMPLE_08_NO_HAL_PWM
    bool "08_no_hal_pwm"
    depends on ARCH_CORTEX_M4

config SAMPLE_09_HAL_CLOCK
    bool "09_hal_clock"
    depends on ARCH_CORTEX_M4

config SAMPLE_10_NO_HAL_I2C
    bool "10_no_hal_i2c"
    depends on ARCH_CORTEX_M4

config SAMPLE_11_HAL_I2C
    bool "11_hal_i2c"
    select DRV_I2C

config SAMPLE_12_NO_HAL_FLASH
    bool "12_no_hal_flash"
    depends on ARCH_CORTEX_M4

config SAMPLE_13_HAL_FLASH
    bool "13_hal_flash"
    select DRV_FLASH

config SAMPLE_14_HAL_UART_INT
    bool "14_hal_uart_int"

config SAMPLE_15_HAL_UART_DMA
    bool "15_hal_uart_dma"
    depends on ARCH_CORTEX_M4

config SAMPLE_16_HAL_DMA_POLLING_UART
    bool "16_hal_dma_polling_uart"
    depends on ARCH_CORTEX_M4

config SAMPLE_17_HAL_FPU
    bool "17_hal_fpu"
    depends on ARCH_CORTEX_M4

config SAMPLE_18_HAL_CRC
    bool "18_hal_crc"
    select DRV_CRC

config SAMPLE_19_HAL_DMA_I2C
    bool "19_hal_dma_i2c"
    depends on ARCH_CORTEX_M4
    select DRV_I2C

config SAMPLE_20_HAL_SDIO
    bool "20_hal_sdio"
    depends on ARCH_CORTEX_M4
    select DRV_SDIO

config SAMPLE_21_HAL_SDIO_BLOCK
    bool "21_hal_sdio_block"
    depends on ARCH_CORTEX_M4
    select DRV_SDIO

config SAMPLE_22_HAL_FATFS_POSIX
    bool "22_hal_fatfs_posix"
    depends on ARCH_CORTEX_M4
    select DRV_SDIO

config SAMPLE_23_HAL_SDIO_PERF
    bool "23_hal_sdio_perf"
    depends on ARCH_CORTEX_M4
    select DRV_SDIO

config SAMPLE_24_HAL_UART_DMA_BRIDGE
    bool "24_hal_uart_dma_bridge"
    depends on ARCH_CORTEX_M4

config SAMPLE_25_HAL_SPI_ESP_BRIDGE
    bool "25_hal_spi_esp_bridge"
    select DRV_SPI

config SAMPLE_26_HAL_DWT
    bool "26_hal_dwt"
    depends on ARCH_CORTEX_M4
    select DRV_DWT
    select DRV_UART
    select DRV_FPU
    select USE_FPU

endchoice

config SAMPLE
    string
    default "" if SAMPLE_NONE
    default "hal_blink" if SAMPLE_01_HAL_BLINK
    default "no_hal_blink" if SAMPLE_01_NO_HAL_BLINK
    default "hal_pupd" if SAMPLE_02_HAL_PUPD
    default "hal_uart_tx" if SAMPLE_03_HAL_UART_TX
    default "no_hal_uart_tx" if SAMPLE_03_NO_HAL_UART_TX
    default "hal_timer" if SAMPLE_04_HAL_TIMER
    default "hal_systick" if SAMPLE_05_HAL_SYSTICK
    default "hal_blink_delay" if SAMPLE_06_HAL_BLINK_DELAY
    default "hal_pwm" if SAMPLE_07_HAL_PWM
    default "no_hal_pwm" if SAMPLE_08_NO_HAL_PWM
    default "hal_clock" if SAMPLE_09_HAL_CLOCK
    default "no_hal_i2c" if SAMPLE_10_NO_HAL_I2C
    default "hal_i2c" if SAMPLE_11_HAL_I2C
    default "no_hal_flash" if SAMPLE_12_NO_HAL_FLASH
    default "hal_flash" if SAMPLE_13_HAL_FLASH
    default "hal_uart_int" if SAMPLE_14_HAL_UART_INT
    default "hal_uart_dma" if SAMPLE_15_HAL_UART_DMA
    default "hal_dma_polling_uart" if SAMPLE_16_HAL_DMA_POLLING_UART
    default "hal_fpu" if SAMPLE_17_HAL_FPU
    default "hal_crc" if SAMPLE_18_HAL_CRC
    default "hal_dma_i2c" if SAMPLE_19_HAL_DMA_I2C
    default "hal_sdio" if SAMPLE_20_HAL_SDIO
    default "hal_sdio_block" if SAMPLE_21_HAL_SDIO_BLOCK
    default "hal_fatfs_posix" if SAMPLE_22_HAL_FATFS_POSIX
    default "hal_sdio_perf" if SAMPLE_23_HAL_SDIO_PERF
    default "hal_uart_dma_bridge" if SAMPLE_24_HAL_UART_DMA_BRIDGE
    default "hal_spi_esp_bridge" if SAMPLE_25_HAL_SPI_ESP_BRIDGE
    default "hal_dwt" if SAMPLE_26_HAL_DWT
