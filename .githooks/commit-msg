#!/usr/bin/env bash
# commit-msg hook: enforce Conventional Commits format on the subject line.
#
# Format:   <type>[(<scope>)][!]: <subject>
# Types:    feat fix docs style refactor perf test build ci chore revert
# Length:   first line ≤ 72 chars
# Body:     optional, must be separated by a blank line (git enforces this)
#
# Skipped automatically: merges ("Merge "), fixup/squash ("fixup! " /
# "squash! "), and git-generated reverts ("Revert \"...\""). Manual revert
# commits using "revert: <subject>" go through the normal check.
#
# CI runs the same check against every commit in a PR via
# tools/lint_commits.sh, so --no-verify bypasses are caught upstream.

set -eu

COMMIT_MSG_FILE=$1
FIRST_LINE=$(head -n1 "$COMMIT_MSG_FILE")

# Skip auto-generated forms
case "$FIRST_LINE" in
  "Merge "*|"fixup! "*|"squash! "*|"Revert \""*)
    exit 0
    ;;
esac

TYPES='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
# Scope: lowercase alnum + . _ - , (so multi-scope "(uart,dma)" works)
SCOPE='\([a-z0-9][a-z0-9_.,-]*\)'
PATTERN="^(${TYPES})(${SCOPE})?!?: .+$"

fail() {
  echo "" >&2
  echo "  ✗ commit message rejected" >&2
  echo "" >&2
  echo "  Got:" >&2
  echo "      $FIRST_LINE" >&2
  echo "" >&2
  echo "  $1" >&2
  echo "" >&2
  echo "  Expected:  <type>[(<scope>)][!]: <subject>" >&2
  echo "  Types:     ${TYPES//|/, }" >&2
  echo "" >&2
  echo "  Examples:" >&2
  echo "      feat(uart): add async DMA write" >&2
  echo "      fix(caps): hal_fpu_enable absent when DRV_FPU=n" >&2
  echo "      docs: link CoC from README" >&2
  echo "      chore!: drop AVR sub-cap fallback (breaking)" >&2
  echo "" >&2
  echo "  Bypass with --no-verify, but CI runs the same check on the PR." >&2
  echo "" >&2
  exit 1
}

if ! printf '%s' "$FIRST_LINE" | grep -qE "$PATTERN"; then
  fail "Subject does not match the Conventional Commits format."
fi

LEN=${#FIRST_LINE}
if [ "$LEN" -gt 72 ]; then
  fail "Subject is $LEN chars; max is 72."
fi

# If there's a second line, it must be blank (Conventional Commits + git lore).
SECOND_LINE=$(sed -n '2p' "$COMMIT_MSG_FILE" || true)
if [ -n "$SECOND_LINE" ] && [ "${SECOND_LINE:0:1}" != "#" ]; then
  fail "Line 2 must be blank (separator between subject and body)."
fi
