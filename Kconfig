# vim: ft=kconfig
mainmenu "NavHAL Configuration System"

# Platform selection (arch / vendor / family / board) is contributed by
# per-port Kconfig fragments under each port's own source tree (M7 §7.2),
# glob-sourced below. Adding an MCU is purely additive: drop the fragment
# files into src/arch, src/vendor, src/board — no edits to this file.
#
# Each choice sources the ports' "Kconfig.choice" members. Their
# mutual-exclusion default falls out of the `depends on` chain
# (arch ▶ vendor ▶ family ▶ board): exactly one member is visible per
# parent selection, and a choice auto-selects its single visible member,
# so no per-port "default X if PARENT" lines are needed here.

menu "Target Platform Configuration"

choice
    prompt "Processor Architecture"
    default ARCH_CORTEX_M4
    help
      Select the target processor architecture.
source "src/arch/*/Kconfig.choice"
endchoice

choice
    prompt "Vendor"
    help
      Select the silicon vendor.
source "src/vendor/*/Kconfig.choice"
endchoice

choice
    prompt "Vendor Device Family"
    help
      Select the device family within the selected vendor. This is the
      register-layout axis: a single vendor can ship multiple families
      with different register maps (STM32F4 vs STM32F0 vs ...).
source "src/vendor/*/family/*/Kconfig.choice"
endchoice

choice
    prompt "Target Board"
    help
      Select the target development board.
source "src/board/*/Kconfig.choice"
endchoice

# Per-port identity strings (ARCH_ISA / VENDOR / FAMILY / BOARD /
# CMAKE_SYSTEM_PROCESSOR) and per-arch build defaults.
source "src/arch/*/Kconfig"
source "src/vendor/*/Kconfig"
source "src/vendor/*/family/*/Kconfig"
source "src/board/*/Kconfig"

endmenu

menu "System & Features Configuration"

# Arch-specific peripheral toggles (FPU, DMA, DWT, ...) ship with their
# arch under src/arch/<isa>/Kconfig.features. osource: not every arch has
# arch-specific features.
osource "src/arch/*/Kconfig.features"

config DRV_CRC
    bool "Enable Hardware CRC Unit"
    default n
    help
      Enables hardware cyclic redundancy check unit support.

endmenu

menu "HAL Drivers Configuration"
    depends on ARCH_CORTEX_M4 || ARCH_AVR8

config DRV_CLOCK
    bool "Enable Clock Driver"
    default y

config DRV_INTERRUPT
    bool "Enable Interrupt Driver"
    default y

config DRV_GPIO
    bool "Enable GPIO Driver"
    default y

config DRV_TIMER
    bool "Enable Timer Driver"
    default y
    select DRV_CLOCK
    select DRV_INTERRUPT

config DRV_UART
    bool "Enable UART Driver"
    default y
    select DRV_GPIO
    select DRV_CLOCK
    select DRV_INTERRUPT

config DRV_UART_DMA
    bool "Enable DMA-backed UART API"
    default y if DRV_UART && ARCH_CORTEX_M4
    depends on DRV_UART
    select DRV_DMA if ARCH_CORTEX_M4
    help
      Compile the hal_uart_write_dma / init_dma_rx variants. Disable to
      drop the DMA backend from a DMA-enabled build (e.g. to save flash
      when DMA is only used by other drivers). Enabling this is what pulls
      DRV_DMA in for the UART driver on Cortex-M4 — DRV_UART itself does
      not require DMA.

config DRV_I2C
    bool "Enable I2C Driver"
    default n
    select DRV_CLOCK
    select DRV_INTERRUPT

config DRV_I2C_DMA
    bool "Enable DMA-backed I2C API"
    default y if DRV_I2C && ARCH_CORTEX_M4
    depends on DRV_I2C
    select DRV_DMA if ARCH_CORTEX_M4
    help
      Compile hal_i2c_read_regs_dma. Disable to drop the DMA backend
      from a DMA-enabled I2C build.

config DRV_SPI
    bool "Enable SPI Driver"
    default n
    select DRV_GPIO
    select DRV_TIMER

config DRV_PWM
    bool "Enable PWM Driver"
    default n
    select DRV_CLOCK
    select DRV_TIMER

config DRV_SDIO
    bool "Enable SDIO Driver"
    depends on ARCH_CORTEX_M4
    default n
    select DRV_CLOCK
    select DRV_GPIO
    select DRV_INTERRUPT
    select DRV_TIMER

config DRV_SDIO_DMA
    bool "Enable DMA-backed SDIO async API"
    default y if DRV_SDIO && ARCH_CORTEX_M4
    depends on DRV_SDIO
    select DRV_DMA if ARCH_CORTEX_M4
    help
      Compile the hal_sdio_*_async block-transfer variants. Disable to
      restrict SDIO to the polled (synchronous) API.

config DRV_FLASH
    bool "Enable Flash Driver"
    default n

endmenu

menu "Build Options"

# Per-arch toolchain identity: the prompt lives here (shared, overridable
# in menuconfig); each arch contributes its "default ... if ARCH_*" under
# src/arch/<isa>/Kconfig.
config TOOLCHAIN_PREFIX
    string "Toolchain Binary Prefix"
    help
      Prefix for the toolchain binaries (e.g. arm-none-eabi-, avr-).

config STANDALONE
    bool "Build Standalone Samples (without full HAL)"
    default n

# Sample selection lives in samples/Kconfig (M7 §7.3). Adding a new
# sample is one edit there, no root-Kconfig change.
source "samples/Kconfig"


config TEST
    bool "Build Unit Tests"
    default n

config FLASHER
    string "Binary Flasher Tool"

config FLASH_ADDRESS
    string "Flash Target Address"

endmenu
